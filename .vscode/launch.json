{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "hello_world (blues 4/4)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hello_world.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["--prompt", "texas blues backing band, piano, rhythm guitar", "--tempo", "100", "--time-sig", "4/4"]
    },
    {
      "name": "hello_world (waltz 3/4)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hello_world.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["--prompt", "waltz", "--tempo", "120", "--time-sig", "3/4"]
    }
  ]
}
