{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "staged_band (--generation-debug, --chords)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/staged_band.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["--generation-debug", "--prompt", "rock guitar", "--tempo", "100", "--time-sig", "4/4", "--chords", "C, C, C, C, F, F, C, C", "--temperature", "1.0"]
    },
    {
      "name": "staged_band (backing-only, --chords)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/staged_band.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["--backing-only", "--prompt", "rock guitar", "--tempo", "100", "--time-sig", "4/4", "--chords", "C, C, C, C, F, F, C, C", "--temperature", "1.0"]
    },
    {
      "name": "staged_band (backing-only, magenta defaults)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/staged_band.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["--backing-only", "--no-repeat", "--prompt", "rock rhythm guitar", "--tempo", "100", "--time-sig", "4/4", "--chords", "C, C, C, C, F, F, C, C", "--style-strength", "3.0", "--cfg-notes", "1.0", "--temperature", "1.3", "--top-k", "40"]
    },
    {
      "name": "staged_band (baked drum loop)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/staged_band.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "args": ["--prompt", "rock guitar", "--tempo", "80", "--time-sig", "4/4", "--input-device", "iD4", "--input-channel", "1", "--output-device", "iD4", "--duplex", "--temperature", "0.90"]
    }
  ]
}
